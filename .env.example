# ── National Grid credentials (your account) ───────────────────────────────
# The email + password you use at https://myaccount.nationalgrid.com.
# These remain the bootstrap/fallback: they're used when no encrypted login has
# been stored in the DB (see NGRID_SECRET_KEY below).
NGRID_USER=you@example.com
NGRID_PASS=your-password-here

# Encryption key for the credential store. Required to store/use National Grid
# logins encrypted at rest (AES-256-GCM) in the DB instead of the env vars above;
# the key itself is never stored in the DB. Generate one with:
#   openssl rand -base64 32
# Env creds (NGRID_USER/NGRID_PASS) stay the fallback when no stored login exists.
NGRID_SECRET_KEY=

# ── Database ───────────────────────────────────────────────────────────────
# These are used by both the postgres container and the app.
DB_USER=ngrid
DB_PASSWORD=change-me-to-a-long-random-string
DB_NAME=ngrid

# Connection string the app uses (host = the compose service name).
DATABASE_URL=postgresql://ngrid:change-me-to-a-long-random-string@ngrid_postgres:5432/ngrid?schema=public

# ── App ────────────────────────────────────────────────────────────────────
TZ=America/New_York
# Port published on the host for the dashboard UI.
APP_PORT=3000
# Where bill PDFs are stored on the host (the DB and session use Docker volumes).
PDF_DIR=./data/pdfs

# Scheduler: set to "false" to disable automatic bill checking (manual only).
SCHEDULER_ENABLED=true

# ── Backups ────────────────────────────────────────────────────────────────
# Before applying a schema-changing upgrade, the app dumps the database to this
# host dir (one gzipped pg_dump per upgrade) so there's always a restore point.
# Restore with:  gunzip -c <file>.sql.gz | docker compose exec -T ngrid_postgres psql -U ngrid -d ngrid
BACKUP_DIR=./data/backups
# Take that pre-upgrade backup (set "false" to skip — not recommended).
BACKUP_BEFORE_MIGRATE=true
# How many pre-upgrade backups to keep (older ones are pruned).
BACKUP_RETENTION=10
