# ── National Grid credentials (your account) ───────────────────────────────
# The email + password you use at https://myaccount.nationalgrid.com.
# These remain the bootstrap/fallback: they're used when no encrypted login has
# been stored in the DB (see NGRID_SECRET_KEY below).
NGRID_USER=you@example.com
NGRID_PASS=your-password-here

# Encryption key for the credential store. Required to store/use National Grid
# logins encrypted at rest (AES-256-GCM) in the DB instead of the env vars above;
# the key itself is never stored in the DB. Generate one with:
#   openssl rand -base64 32
# Env creds (NGRID_USER/NGRID_PASS) stay the fallback when no stored login exists.
# BACK THIS KEY UP SEPARATELY: it is NOT included in the GET /api/backup archive, and
# without it a restored backup cannot decrypt your stored NG-logins (the DB only holds
# ciphertext). If you leave it unset, the auto-generated key lives in session/secret.key.
NGRID_SECRET_KEY=

# ── Database ───────────────────────────────────────────────────────────────
# These are used by both the postgres container and the app.
DB_USER=ngrid
DB_PASSWORD=change-me-to-a-long-random-string
DB_NAME=ngrid

# Connection string the app uses (host = the compose service name).
DATABASE_URL=postgresql://ngrid:change-me-to-a-long-random-string@ngrid_postgres:5432/ngrid?schema=public
#
# EXTERNAL Postgres: a single DATABASE_URL is enough — URL-encode the password so
# libpq can parse it. Setting DB_USER/DB_NAME/DB_PASSWORD (with the RAW password) is
# RECOMMENDED if your password contains special characters (%, @, #, $): the
# pre-migrate backup then connects with those discrete libpq params instead of
# relying on the URL's percent-encoding. Either way the backup FAILS CLOSED —
# refusing the schema sync rather than silently skipping the backup — if it can't
# connect at all.

# ── App ────────────────────────────────────────────────────────────────────
TZ=America/New_York
# Port published on the host for the dashboard UI.
APP_PORT=3000
# Where bill PDFs are stored on the host (the DB and session use Docker volumes).
PDF_DIR=./data/pdfs

# Scheduler: set to "false" to disable automatic bill checking (manual only).
SCHEDULER_ENABLED=true

# ── New-bill notifications (off by default) ────────────────────────────────
# When a SCHEDULED check finds a new bill, send exactly one notification per new
# bill (amount = current charges, service period, statement date, and a dashboard
# link if APP_BASE_URL is set). Manual refreshes stay silent. Dedupe is tracked in
# the DB (AppSetting `lastNotifiedStatementDate`) so restarts never double-send;
# the first scheduled run after enabling only seeds that watermark — it does NOT
# replay your whole bill history.
#
# Pick a channel explicitly, or leave NOTIFY_CHANNEL unset and the app infers it
# from whichever block below you fill in (webhook > ntfy > smtp). "off" disables.
# NOTIFY_CHANNEL=off            # off | webhook | ntfy | smtp
# Public URL of this dashboard, used to build the link in the notification.
# APP_BASE_URL=https://ember.example.com

# webhook: HTTP POST a JSON body to this URL (no extra dependency).
# NOTIFY_WEBHOOK_URL=https://example.com/hook

# ntfy: POST to a topic on an ntfy server (https://ntfy.sh by default).
# NTFY_URL=https://ntfy.sh
# NTFY_TOPIC=my-ngrid-bills
# NTFY_TOKEN=                   # optional bearer token for protected topics

# smtp (email, via nodemailer): HOST/FROM/TO are required; the rest are optional.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587                 # 465 ⇒ implicit TLS unless SMTP_SECURE overrides
# SMTP_SECURE=                  # "true"/"false" to force; default true only on 465
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=ngrid@example.com
# SMTP_TO=you@example.com

# ── Smart-meter interval ingest (optional) ─────────────────────────────────
# How far back (days) the WIDE hourly-gql backstop pulls interval usage for each
# AMI meter. Continuous hourly for both fuels; defaults to 35 if unset.
# INTERVAL_WINDOW_DAYS=35
# One-time backfill floor (YYYY-MM-DD) for the hourly-gql pull; overrides the
# window above. The fill-only upsert makes any overlap idempotent.
# INTERVAL_BACKFILL_FROM=
# How far back (days) the 15-min REST overlay reaches. Keep this SHORT (default
# 2): the amiadapter endpoint only returns 15-minute electric reads for a narrow
# window and 400s on longer ranges — the hourly gql above is the wide backstop.
# INTERVAL_REST_WINDOW_DAYS=2

# ── Backups ────────────────────────────────────────────────────────────────
# Before applying a schema-changing upgrade, the app dumps the database to this
# host dir (one gzipped pg_dump per upgrade) so there's always a restore point.
# Restore with:  gunzip -c <file>.sql.gz | docker compose exec -T ngrid_postgres psql -U ngrid -d ngrid
BACKUP_DIR=./data/backups
# Take that pre-upgrade backup (set "false" to skip — not recommended).
BACKUP_BEFORE_MIGRATE=true
# How many pre-upgrade backups to keep (older ones are pruned).
BACKUP_RETENTION=10
