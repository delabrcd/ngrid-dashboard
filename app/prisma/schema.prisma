generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// A stored National Grid login (the email/password used at the B2C portal).
// One login fans out to several Account rows (multi-premise / linked accounts).
// The password is encrypted at rest with AES-256-GCM (see lib/crypto.ts); the
// key lives only in the NGRID_SECRET_KEY env var, never in the DB. Env creds
// (NGRID_USER/NGRID_PASS) remain the bootstrap fallback when no row exists.
model NgLogin {
  id             Int       @id @default(autoincrement())
  label          String
  username       String
  ciphertext     String // base64 AES-256-GCM ciphertext of the password
  iv             String // base64 12-byte GCM nonce
  authTag        String // base64 GCM auth tag
  status         String? // e.g. last pre-flight result (OK / failed / MFA)
  lastVerifiedAt DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  accounts Account[]
}

// A National Grid billing account. One login can expose several (multi-premise).
// region / companyCode are read from the account API so other NG regions work
// with no code changes.
model Account {
  id             Int      @id @default(autoincrement())
  accountNumber  String   @unique
  // The stored login this account was discovered through. Nullable: accounts
  // bootstrapped from env creds (NGRID_USER/NGRID_PASS) have no NgLogin row.
  loginId        Int?
  login          NgLogin? @relation(fields: [loginId], references: [id], onDelete: SetNull)
  accountLink    String?
  region         String?
  companyCode    String?
  serviceAddress String?
  fuelTypes      String[] @default([])
  premiseNumber  String?
  customerNumber String?
  // Geocoded once from serviceAddress (Open-Meteo) and cached for the historical
  // weather sync; null until the first successful geocode.
  latitude       Float?
  longitude      Float?
  firstSeenAt    DateTime @default(now())
  updatedAt      DateTime @updatedAt

  bills          Bill[]
  usages         Usage[]
  costs          Cost[]
  scrapeRuns     ScrapeRun[]
  scheduleState  ScheduleState?
  weatherDaily   WeatherDaily[]
  notifications  Notification[]
  intervalUsages IntervalUsage[]
  scheduledTasks ScheduledTask[]
}

// Smart-meter AMI interval usage (issue #76). One row per metering interval per
// fuel, pulled from the portal's amiadapter REST endpoint when a meter reports
// hasAmiSmartMeter. PURELY additive: never feeds billed-cost numbers or
// /api/verify (the bill PDF stays the source of truth). intervalStart is the UTC
// instant the interval begins; intervalSeconds is its length (900=15-min, 3600=
// hourly, 86400=daily) so DST fall-back's two distinct UTC instants don't collide.
model IntervalUsage {
  id              Int      @id @default(autoincrement())
  account         Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  accountId       Int
  fuelType        String // ELECTRIC | GAS
  intervalStart   DateTime // UTC; start of the interval
  intervalSeconds Int // 900 (15-min) | 3600 | 86400
  quantity        Float
  unit            String // kWh | therms
  source          String   @default("portal")

  @@unique([accountId, fuelType, intervalStart, intervalSeconds])
  @@index([accountId, fuelType, intervalStart])
}

// One statement. PDF is stored on disk; pdfPath points at it.
model Bill {
  id             Int       @id @default(autoincrement())
  account        Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  accountId      Int
  statementDate  DateTime  @db.Date
  periodFrom     DateTime? @db.Date
  periodTo       DateTime? @db.Date
  totalDueAmount Float? // statement "Amount Due" from the API (may include carryover)
  currentCharges Float? // this period's energy charges from the bill PDF (used for cost analysis)
  status         String?
  pdfPath        String?
  createdAt      DateTime  @default(now())

  @@unique([accountId, statementDate])
  @@index([accountId, statementDate])
}

// Monthly usage quantity per fuel/usage type (TOTAL_KWH, THERMS).
model Usage {
  id              Int       @id @default(autoincrement())
  account         Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  accountId       Int
  usageType       String // TOTAL_KWH | THERMS
  periodYearMonth Int // e.g. 202605
  dateFrom        DateTime? @db.Date
  dateTo          DateTime? @db.Date
  quantity        Float
  unit            String // kWh | therms

  @@unique([accountId, usageType, periodYearMonth])
}

// Monthly cost per fuel. kind=SUPPLY is the usage/supply charge; kind=BILL_AMOUNT
// is the per-fuel slice of the total bill (delivery = BILL_AMOUNT - SUPPLY).
model Cost {
  id              Int       @id @default(autoincrement())
  account         Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  accountId       Int
  fuelType        String // ELECTRIC | GAS
  kind            String // SUPPLY | BILL_AMOUNT
  periodYearMonth Int
  dateFrom        DateTime? @db.Date
  dateTo          DateTime? @db.Date
  amount          Float

  @@unique([accountId, fuelType, kind, periodYearMonth])
}

// Monthly average temperature for a region (shared across accounts in that region).
// source distinguishes National Grid's ~24-month feed ("ng", the fallback) from
// Open-Meteo's full-history rollup ("open-meteo", the primary). Both can coexist
// for the same region/month without colliding; the read layer prefers external.
model Weather {
  id             Int      @id @default(autoincrement())
  region         String
  monthYear      DateTime @db.Date
  avgTemperature Float
  unit           String   @default("F")
  source         String   @default("ng")

  @@unique([region, monthYear, source])
}

// Daily temperatures from Open-Meteo's archive, scoped to the account whose
// location was geocoded. Issue #5 (degree-days) computes HDD/CDD per bill PERIOD
// from these, so we persist the full daily resolution, not just the monthly mean.
model WeatherDaily {
  id        Int      @id @default(autoincrement())
  account   Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  accountId Int
  date      DateTime @db.Date
  tMean     Float // degrees, in `unit`
  tMin      Float?
  tMax      Float?
  unit      String   @default("F")
  source    String   @default("open-meteo")

  @@unique([accountId, date, source])
  @@index([accountId, date])
}

enum ScrapeTrigger {
  MANUAL
  SCHEDULED
}

enum ScrapeStatus {
  RUNNING
  SUCCESS
  ERROR
}

// Audit trail + drives the "last checked" badge and the manual-button progress.
model ScrapeRun {
  id         Int           @id @default(autoincrement())
  account    Account?      @relation(fields: [accountId], references: [id], onDelete: SetNull)
  accountId  Int?
  trigger    ScrapeTrigger
  status     ScrapeStatus  @default(RUNNING)
  startedAt  DateTime      @default(now())
  finishedAt DateTime?
  billsAdded Int           @default(0)
  message    String?

  @@index([startedAt])
}

// Simple key/value store for runtime app settings (e.g. schedulerEnabled).
model AppSetting {
  key   String @id
  value String
}

// Persistent server-side notification log (notification-log feature). Replaces the
// derive-from-current-state bell: every new-bill and anomaly EVENT is stored once
// (deduped by a stable `key`) so there's a clickable history with read/unread and
// a "hide read" filter, surviving reloads and populated even when the UI never
// fetched (the scheduled scrape syncs it). NEVER carries a secret — title/message/
// amount/period only; the `payload` holds the AnomalyFlag or bill summary the
// detail modal renders. Additive table (no existing data touched).
model Notification {
  id        Int       @id @default(autoincrement())
  account   Account?  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  accountId Int?
  kind      String // 'bill' | 'anomaly'
  key       String // stable dedupe key: bill:{statementDate} | anomaly:{ym}:{fuel}:{metric}
  title     String
  message   String
  payload   Json? // detail data for the detail modal (the AnomalyFlag, or bill summary)
  createdAt DateTime  @default(now())
  readAt    DateTime?

  @@unique([accountId, key])
  @@index([accountId, createdAt])
}

// Generic scheduler task (Scheduler V2, docs/scheduler-v2-plan.md). The scheduler
// is task-agnostic: each tick loads due rows (enabled && nextRunAt <= now),
// dispatches by `kind` to a handler, and writes back the nextRunAt the handler
// returns (null = inactive/one-shot done, never selected as due). Additive table;
// nothing existing is touched. payload is opaque to the runner and NEVER a secret.
model ScheduledTask {
  id         Int       @id @default(autoincrement())
  kind       String // 'full-scrape' | 'pdf-fetch' | 'interval-pull' | 'weather-sync' | 'notify-sync'
  accountId  Int?
  account    Account?  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  payload    Json      @default("{}")
  enabled    Boolean   @default(true)
  nextRunAt  DateTime?
  lastRunAt  DateTime?
  lastStatus String? // 'SUCCESS' | 'ERROR' | 'SKIPPED'
  lastReason String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@unique([kind, accountId])
  @@index([enabled, nextRunAt])
  @@index([kind])
}

// Per-account scheduling: when we predict the next bill and when to next check.
model ScheduleState {
  accountId             Int       @id
  account               Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  predictedNextBillDate DateTime? @db.Date
  nextCheckAt           DateTime?
  lastCheckedAt         DateTime?
}
